{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noImplicitAny": false,
    "strict": false,
    "target": "ES2022",
    "types": ["node", "svelte", "vite/client"]
  },
  "include": ["src/**/*.ts", "src/**/*.svelte", "vite.config.ts"],
  "exclude": ["node_modules", "../.build", "src/**/*.test.ts"]
}
